// RUN: cir-opt %s -cir-to-mlir -o - | FileCheck %s -check-prefix=MLIR

module {
  cir.func @test_unreachable() {
    cir.unreachable
  }

  //      MLIR: func.func @test_unreachable()
  // MLIR-NEXT:   llvm.unreachable

  cir.func @test_trap() {
    cir.trap
  }

  //      MLIR: llvm.func @test_trap()
  // MLIR-NEXT:   "llvm.intr.trap"() : () -> ()
  // MLIR-NEXT:   llvm.unreachable
}
